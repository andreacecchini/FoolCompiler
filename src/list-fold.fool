let
    /* List h :: t. */
    class List (h: int, t: List) {
        fun head: int () h;
        fun tail: List () t;
    }

    /* Abstracts an (int, int) => int function. */
    class BiIntFunction () {
        fun apply: int (x:int, y: int) null;
    }

    /* (x, y) => x + y. */
    class Sum extends BiIntFunction () {
        fun apply: int (x: int, y: int) x + y;
    }

    /* (x, y) => x * y. */
    class Product extends BiIntFunction () {
        fun apply: int (x: int, y: int) x * y;
    }

    /* folding a list using f function starting from acc. */
    fun fold: int (l: List, acc: int, f: BiIntFunction)
            if (l == null)
                then { acc }
                else { fold(l.tail(), f.apply(acc, l.head()), f) };

    /* Empty node list. */
    fun nil: List () null;

    /* Node list. */
    fun cons: List (h: int, t: List) new List(h, t);

    var l: List = cons(1, cons(2, cons(3, cons(4, nil()))));
in
    print(fold(l, 0, new Sum()));
