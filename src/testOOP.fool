let
    class Account (money:int) {
        fun getMon:int ()
            let
                var bonus: int = 10;
            in money + bonus;
    }
    class Person (age:int) {
        fun getAge:int() age;
    }
    var money: int = 100;
    var a: Account = new Account(money);
    var p: Person = new Person(18);
in
    print(a.getMon());
